# ---------------------------------------------------------------
# OmniSight 环境变量模板
# 使用方式：cp .env.example .env，然后按需修改
# ---------------------------------------------------------------

# PostgreSQL（使用 TimescaleDB 镜像）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omnisight

# Redis（Bull Queue 消息队列 + 布隆过滤器去重 + 会话缓存）
REDIS_URL=redis://localhost:6379

# JWT / API Key 校验密钥
JWT_SECRET=change-me-in-production

# Gateway 服务端口
PORT=3000
NODE_ENV=development

# Console 前端请求网关的基础地址
VITE_API_BASE=http://localhost:3000

# ---------------------------------------------------------------
# 告警配置
# ---------------------------------------------------------------

# 是否启用告警功能（true/false）
ALERT_ENABLED=false

# 错误次数阈值：超过此数值触发告警
ALERT_THRESHOLD=100

# 统计时间窗口（分钟）：统计最近 N 分钟内的错误次数
ALERT_WINDOW_MINUTES=5

# 冷却时间（分钟）：同一错误在冷却期内不重复告警
ALERT_COOLDOWN_MINUTES=30

# 飞书机器人 Webhook URL（在飞书群组中添加自定义机器人获取）
ALERT_FEISHU_WEBHOOK=

# 飞书机器人签名密钥（可选，启用签名验证时需要）
ALERT_FEISHU_SECRET=
