{
  "compilerOptions": {
    /* ---------------------------------------------------------------
     * NestJS 标准 TypeScript 编译配置
     * module: commonjs — NestJS 运行在 Node.js 上，使用 CommonJS 模块系统
     * emitDecoratorMetadata: true — NestJS 依赖装饰器元数据实现依赖注入
     * experimentalDecorators: true — 启用装饰器语法（@Module, @Controller 等）
     * esModuleInterop: true — 允许 CommonJS 和 ES Module 混用（import x from 'y'）
     * strict: true — 启用所有严格类型检查，提高代码质量
     * --------------------------------------------------------------- */
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
