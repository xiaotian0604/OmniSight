{
  "name": "@omnisight/sdk",
  "version": "0.0.1",
  "description": "OmniSight 前端采集 SDK — 轻量级、无侵入的全链路可观测性数据采集工具",
  "main": "./dist/omnisight.cjs.js",
  "module": "./dist/omnisight.esm.js",
  "browser": "./dist/omnisight.iife.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/omnisight.esm.js",
      "require": "./dist/omnisight.cjs.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "build:watch": "rollup -c rollup.config.ts --configPlugin typescript --watch",
    "dev": "rollup -c rollup.config.ts --configPlugin typescript --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo 'no lint configured'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@omnisight/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "rollup": "^4.28.0",
    "@rollup/plugin-terser": "^0.4.0",
    "tslib": "^2.8.0",
    "typescript": "^5.0.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "rrweb": "^2.0.0-alpha.0",
    "web-vitals": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "rrweb": {
      "optional": true
    },
    "web-vitals": {
      "optional": true
    }
  }
}
